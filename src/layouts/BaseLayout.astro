---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Your AI learning platform for engineers and enthusiasts. Stay ahead with AI news, videos, and training.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | AI Engineers Community</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body class="min-h-screen bg-white">
    <!-- Navigation -->
    <header class="sticky top-0 z-50 bg-white border-b border-gray-100 shadow-sm">
      <div class="container-wide">
        <nav class="flex items-center justify-between h-16">
          <!-- Logo -->
          <a href="/" class="flex items-center gap-2">
            <div class="w-8 h-8 bg-brand-600 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
              </svg>
            </div>
            <span class="text-xl font-bold text-gray-900">AI Engineers</span>
          </a>

          <!-- Desktop Nav -->
          <div class="hidden md:flex items-center gap-1">
            <a href="/" class="px-4 py-2 text-sm font-medium text-gray-700 hover:text-brand-600 hover:bg-brand-50 rounded-lg transition-colors">Home</a>
            <a href="/news" class="px-4 py-2 text-sm font-medium text-gray-700 hover:text-brand-600 hover:bg-brand-50 rounded-lg transition-colors">AI-News</a>
            <a href="/videos" class="px-4 py-2 text-sm font-medium text-gray-700 hover:text-brand-600 hover:bg-brand-50 rounded-lg transition-colors">Videos</a>
            <a href="/training" class="px-4 py-2 text-sm font-medium text-gray-700 hover:text-brand-600 hover:bg-brand-50 rounded-lg transition-colors">Training</a>
          </div>

          <!-- CTA -->
          <div class="hidden md:flex items-center gap-3">
            <a href="/training" class="btn-primary text-sm py-2 px-4">
              Join Community
            </a>
          </div>

          <!-- Mobile menu button -->
          <button id="mobile-menu-btn" class="md:hidden p-2 rounded-lg text-gray-700 hover:bg-gray-100">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </nav>

        <!-- Mobile menu -->
        <div id="mobile-menu" class="hidden md:hidden py-4 border-t border-gray-100">
          <div class="flex flex-col gap-1">
            <a href="/" class="px-4 py-2 text-sm font-medium text-gray-700 hover:text-brand-600">Home</a>
            <a href="/news" class="px-4 py-2 text-sm font-medium text-gray-700 hover:text-brand-600">AI-News</a>
            <a href="/videos" class="px-4 py-2 text-sm font-medium text-gray-700 hover:text-brand-600">Videos</a>
            <a href="/training" class="px-4 py-2 text-sm font-medium text-gray-700 hover:text-brand-600">Training</a>
            <div class="pt-2 px-4">
              <a href="/training" class="btn-primary text-sm w-full justify-center">Join Community</a>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- Page Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-gray-900 text-gray-300 mt-20">
      <div class="container-wide py-12">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
          <div class="col-span-1 md:col-span-2">
            <div class="flex items-center gap-2 mb-4">
              <div class="w-8 h-8 bg-brand-600 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                </svg>
              </div>
              <span class="text-xl font-bold text-white">AI Engineers</span>
            </div>
            <p class="text-sm text-gray-400 max-w-sm">
              Your learning platform for AI engineering. Stay up to date with the latest developments, tools, and techniques in AI automation.
            </p>
          </div>

          <div>
            <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Platform</h3>
            <ul class="space-y-2">
              <li><a href="/" class="text-sm hover:text-white transition-colors">Home</a></li>
              <li><a href="/news" class="text-sm hover:text-white transition-colors">AI-News</a></li>
              <li><a href="/videos" class="text-sm hover:text-white transition-colors">Videos</a></li>
              <li><a href="/training" class="text-sm hover:text-white transition-colors">Training</a></li>
            </ul>
          </div>

          <div>
            <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Community</h3>
            <ul class="space-y-2">
              <li><a href="#" class="text-sm hover:text-white transition-colors">Newsletter</a></li>
              <li><a href="#" class="text-sm hover:text-white transition-colors">Discord</a></li>
              <li><a href="#" class="text-sm hover:text-white transition-colors">GitHub</a></li>
              <li><a href="#" class="text-sm hover:text-white transition-colors">About</a></li>
            </ul>
          </div>
        </div>

        <div class="border-t border-gray-800 mt-8 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
          <p class="text-sm text-gray-500">&copy; 2026 AI Engineers Community. All rights reserved.</p>
          <div class="flex gap-4">
            <a href="#" class="text-sm text-gray-500 hover:text-white transition-colors">Privacy</a>
            <a href="#" class="text-sm text-gray-500 hover:text-white transition-colors">Terms</a>
            <a href="#" class="text-sm text-gray-500 hover:text-white transition-colors">Imprint</a>
          </div>
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>
