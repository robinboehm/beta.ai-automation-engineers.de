---
import BaseLayout from '../layouts/BaseLayout.astro';
import { newsItems, categories } from '../data/news';

// For static rendering we show all items; filtering happens client-side
---

<BaseLayout title="AI News" description="Stay up to date with the latest AI news, releases, research, and industry updates.">
  <!-- Page Header -->
  <section class="bg-gradient-to-br from-gray-900 to-brand-900 text-white py-16">
    <div class="container-wide">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 bg-white/10 rounded-full px-4 py-1.5 text-sm font-medium mb-4">
          <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
          Updated daily
        </div>
        <h1 class="text-4xl md:text-5xl font-extrabold mb-4">AI News</h1>
        <p class="text-lg text-gray-300">
          Curated daily briefings on AI releases, research breakthroughs, business developments, and new tools. No hype — just signal.
        </p>
      </div>
    </div>
  </section>

  <!-- Filter Bar -->
  <section class="sticky top-16 z-40 bg-white border-b border-gray-100 shadow-sm">
    <div class="container-wide">
      <div class="flex items-center gap-2 py-3 overflow-x-auto scrollbar-hide">
        {categories.map((cat) => (
          <button
            data-category={cat}
            class={`filter-btn flex-shrink-0 px-4 py-1.5 rounded-full text-sm font-medium transition-colors ${
              cat === 'all'
                ? 'bg-brand-600 text-white'
                : 'bg-gray-100 text-gray-600 hover:bg-gray-200'
            }`}
          >
            {cat.charAt(0).toUpperCase() + cat.slice(1)}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- News Grid -->
  <section class="py-12">
    <div class="container-wide">
      <div id="news-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {newsItems.map((item) => (
          <article
            data-category={item.category}
            class="news-card group border border-gray-100 rounded-2xl p-6 hover:border-brand-200 hover:shadow-md transition-all duration-200 bg-white"
          >
            <div class="flex items-center gap-2 mb-3">
              <span class={`text-xs font-semibold px-2.5 py-1 rounded-full capitalize ${
                item.category === 'releases' ? 'bg-purple-100 text-purple-700' :
                item.category === 'research' ? 'bg-green-100 text-green-700' :
                item.category === 'business' ? 'bg-amber-100 text-amber-700' :
                'bg-blue-100 text-blue-700'
              }`}>{item.category}</span>
              <time class="text-xs text-gray-400" datetime={item.date}>
                {new Date(item.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
              </time>
            </div>

            <h2 class="text-base font-bold text-gray-900 mb-2 group-hover:text-brand-600 transition-colors leading-snug">
              <a href={item.url} class="hover:underline">{item.title}</a>
            </h2>

            <p class="text-sm text-gray-600 mb-4 leading-relaxed line-clamp-3">{item.excerpt}</p>

            <div class="flex items-center justify-between">
              <div class="text-xs text-gray-400">
                via <a href={item.sourceUrl} class="text-brand-500 hover:underline font-medium" target="_blank" rel="noopener noreferrer">{item.source}</a>
              </div>
              <a href={item.url} class="text-xs font-semibold text-brand-600 hover:text-brand-700 flex items-center gap-1">
                Read
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>

      <!-- Empty state -->
      <div id="empty-state" class="hidden text-center py-16">
        <div class="text-gray-400 mb-4">
          <svg class="w-12 h-12 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <p class="text-gray-500">No articles in this category yet.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.news-card');
  const emptyState = document.getElementById('empty-state');

  function setActiveFilter(category: string) {
    // Update button states
    filterBtns.forEach(btn => {
      const isActive = btn.dataset.category === category;
      btn.className = `filter-btn flex-shrink-0 px-4 py-1.5 rounded-full text-sm font-medium transition-colors ${
        isActive ? 'bg-brand-600 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'
      }`;
    });

    // Filter cards
    let visibleCount = 0;
    cards.forEach(card => {
      const show = category === 'all' || card.dataset.category === category;
      card.style.display = show ? '' : 'none';
      if (show) visibleCount++;
    });

    emptyState?.classList.toggle('hidden', visibleCount > 0);
  }

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      setActiveFilter(btn.dataset.category ?? 'all');
    });
  });
</script>
