---
import BaseLayout from '../layouts/BaseLayout.astro';
import { videos } from '../data/videos';
---

<BaseLayout title="Videos" description="Learn AI engineering through in-depth video tutorials from experts.">
  <!-- Page Header -->
  <section class="bg-gradient-to-br from-gray-900 to-brand-900 text-white py-16">
    <div class="container-wide">
      <div class="max-w-2xl">
        <h1 class="text-4xl md:text-5xl font-extrabold mb-4">Videos</h1>
        <p class="text-lg text-gray-300">
          Deep-dive tutorials and expert talks on AI engineering — from prompt design to building production-grade systems.
        </p>
      </div>
    </div>
  </section>

  <!-- Videos Grid -->
  <section class="py-12">
    <div class="container-wide">
      <!-- Stats bar -->
      <div class="flex items-center justify-between mb-8">
        <p class="text-sm text-gray-500">{videos.length} videos available</p>
        <div class="flex items-center gap-2">
          <span class="text-sm text-gray-500">Sort by:</span>
          <select class="text-sm border border-gray-200 rounded-lg px-3 py-1.5 text-gray-700 focus:outline-none focus:ring-2 focus:ring-brand-500">
            <option>Newest first</option>
            <option>Most popular</option>
          </select>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {videos.map((video) => (
          <article class="group bg-white rounded-2xl overflow-hidden shadow-sm border border-gray-100 hover:shadow-lg transition-all duration-300">
            <!-- Thumbnail -->
            <div class="relative aspect-video overflow-hidden bg-gray-100">
              <img
                src={video.thumbnail}
                alt={video.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
              <!-- Overlay with play button -->
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent group-hover:from-black/40 transition-all flex items-center justify-center">
                <div class="w-14 h-14 bg-white/90 backdrop-blur-sm rounded-full flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform duration-200">
                  <svg class="w-6 h-6 text-brand-600 ml-1" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M8 5v14l11-7z" />
                  </svg>
                </div>
              </div>
              <!-- Duration badge -->
              <span class="absolute bottom-2 right-2 bg-black/75 text-white text-xs px-2 py-0.5 rounded font-mono backdrop-blur-sm">
                {video.duration}
              </span>
            </div>

            <!-- Content -->
            <div class="p-5">
              <!-- Tags -->
              <div class="flex flex-wrap gap-1.5 mb-3">
                {video.tags.map((tag) => (
                  <span class="text-xs bg-brand-50 text-brand-600 px-2 py-0.5 rounded-full font-medium">{tag}</span>
                ))}
              </div>

              <h2 class="font-bold text-gray-900 text-base mb-2 leading-snug group-hover:text-brand-600 transition-colors">
                <a href={video.videoUrl}>{video.title}</a>
              </h2>

              <p class="text-sm text-gray-500 mb-4 line-clamp-2 leading-relaxed">{video.description}</p>

              <!-- Footer -->
              <div class="flex items-center justify-between pt-3 border-t border-gray-100">
                <div class="flex items-center gap-2">
                  <div class="w-7 h-7 rounded-full bg-brand-100 text-brand-700 flex items-center justify-center text-xs font-bold">
                    {video.instructor.split(' ').map(n => n[0]).join('').slice(0, 2)}
                  </div>
                  <span class="text-xs text-gray-600 font-medium">{video.instructor}</span>
                </div>
                <time class="text-xs text-gray-400" datetime={video.date}>
                  {new Date(video.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </time>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Upgrade CTA -->
  <section class="py-16 bg-gray-50">
    <div class="container-wide">
      <div class="bg-gradient-to-br from-brand-600 to-brand-800 rounded-3xl p-8 md:p-12 text-white text-center">
        <h2 class="text-2xl md:text-3xl font-bold mb-3">Want access to all premium videos?</h2>
        <p class="text-blue-100 mb-8 max-w-xl mx-auto">
          Upgrade to our Pro plan for unlimited access to 180+ videos, course tracks, and live Q&A sessions with instructors.
        </p>
        <a href="/training" class="inline-flex items-center px-8 py-4 bg-white text-brand-700 font-bold rounded-xl hover:bg-blue-50 transition-colors">
          View Training Plans
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
